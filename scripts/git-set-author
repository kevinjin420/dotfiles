#!/usr/bin/env bash
set -euo pipefail

if ! git rev-parse --git-dir &>/dev/null; then
    echo "error: not in a git repository" >&2
    exit 1
fi

ref="${1:-HEAD}"

if ! commit_hash=$(git rev-parse --verify "$ref^{commit}" 2>/dev/null); then
    echo "error: '$ref' is not a valid commit ref" >&2
    exit 1
fi

current_name=$(git config user.name 2>/dev/null || true)
current_email=$(git config user.email 2>/dev/null || true)

read -r -p "Name${current_name:+ [$current_name]}: " name
name="${name:-$current_name}"

read -r -p "Email${current_email:+ [$current_email]}: " email
email="${email:-$current_email}"

if [[ -z "$name" || -z "$email" ]]; then
    echo "error: name and email are required" >&2
    exit 1
fi

head_hash=$(git rev-parse HEAD)

if [[ "$commit_hash" == "$head_hash" ]]; then
    GIT_COMMITTER_NAME="$name" GIT_COMMITTER_EMAIL="$email" \
        git commit --amend --author="$name <$email>" --no-edit
else
    if git rev-parse --verify "${commit_hash}^" &>/dev/null; then
        range="${commit_hash}^..HEAD"
    else
        range="HEAD"
    fi

    FILTER_BRANCH_SQUELCH_WARNING=1 git filter-branch -f \
        --env-filter "
            if [ \"\$GIT_COMMIT\" = \"$commit_hash\" ]; then
                GIT_AUTHOR_NAME=\"$name\"
                GIT_AUTHOR_EMAIL=\"$email\"
                GIT_COMMITTER_NAME=\"$name\"
                GIT_COMMITTER_EMAIL=\"$email\"
                export GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL GIT_COMMITTER_NAME GIT_COMMITTER_EMAIL
            fi
        " \
        "$range"
fi

echo "updated $ref to: $name <$email>"
