[user]
	email = kevinjin0420@gmail.com
	name = kevinjin0420
[init]
	defaultBranch = main
[credential]
	helper = store
[index]
	skipHash = false
[push]
	autoSetupRemote = true
[core]
	editor = nvim
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	hunk-header-decoration-style = green box
	pager = less -RS
	file-style = cyan bold
	file-decoration-style = cyan ol ul
	line-numbers-left-style = green
	line-numbers-right-style = green
	plus-style = syntax "#004d25"
	plus-emph-style = syntax bold "#007a35"

[diff]
	colorMoved = default

[merge]
	conflictstyle = diff3
[alias]
  pull-branch = "!f() { git fetch origin \"$1:$1\"; }; f"
  clean-fetch = "!git fetch --prune && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs -r git branch -D"
  A = add .
  C = commit
  S = status
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	rebase = false
